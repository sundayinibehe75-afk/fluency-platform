# Database
# Full async-compatible PostgreSQL connection string
# Example: postgresql+asyncpg://fluency:password@db:5432/fluency
DATABASE_URL=

# Postgres password (used by the db service directly)
POSTGRES_PASSWORD=

# Authentication
# Long random secret used to sign JWTs — never share or commit this value
JWT_SECRET=

# Stripe
# Secret key from your Stripe dashboard (sk_live_... or sk_test_...)
STRIPE_SECRET_KEY=
# Webhook signing secret from your Stripe webhook endpoint configuration
STRIPE_WEBHOOK_SECRET=

# Resend (transactional email)
# API key from your Resend account
RESEND_API_KEY=

# Daily.co (video lessons)
# API key from your Daily.co account
DAILY_API_KEY=

# Application
# Public URL of the frontend, used for CORS and email links (e.g. https://fluencytutoring.com)
FRONTEND_URL=
# Deployment environment: development | staging | production
ENVIRONMENT=development
